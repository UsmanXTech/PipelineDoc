# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GitHub Configuration
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret_here

# UiPath Configuration
UIPATH_CLIENT_ID=your_uipath_client_id_here
UIPATH_CLIENT_SECRET=your_uipath_client_secret_here
UIPATH_TENANT_NAME=your_uipath_tenant_name_here
UIPATH_ORGANIZATION_ID=your_uipath_organization_id_here

# Database Configuration
POSTGRES_URL=postgresql://admin:password@localhost:5432/pipelinedoc
REDIS_URL=redis://localhost:6379
VECTOR_DB_URL=http://localhost:6333

# OCI Configuration
OCI_COMPARTMENT_ID=your_oci_compartment_id_here
OCI_TENANCY_OCID=your_oci_tenancy_ocid_here
OCI_USER_OCID=your_oci_user_ocid_here
OCI_FINGERPRINT=your_oci_fingerprint_here
OCI_PRIVATE_KEY_PATH=your_oci_private_key_path_here

# Slack Configuration
SLACK_BOT_TOKEN=your_slack_bot_token_here
SLACK_SIGNING_SECRET=your_slack_signing_secret_here
SLACK_CHANNEL_ID=your_slack_channel_id_here

# App Configuration
APP_PORT=3000
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here
